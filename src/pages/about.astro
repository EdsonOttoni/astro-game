---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
import { path } from "../lib/paths";
---

<BaseLayout title="Sobre" description={site.description}>
  <Header slot="header" />

  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-5xl px-5 pt-16 pb-16 sm:px-8 sm:pt-24 sm:pb-20">
      <p
        class="animate-fade-up text-xs font-medium tracking-[0.2em] text-amber uppercase"
      >
        Sobre o estúdio
      </p>
      <h1
        class="animate-fade-up-delay font-display mt-4 text-4xl font-bold tracking-tight text-ink sm:text-6xl"
      >
        {site.name}
      </h1>
      <p
        class="animate-fade-up-delay-2 mt-5 max-w-2xl text-lg text-ink-muted sm:text-xl"
      >
        {site.tagline}
      </p>
    </div>
  </section>

  <section class="border-t border-arcane/10">
    <div class="mx-auto grid max-w-5xl gap-12 px-5 py-14 sm:px-8 sm:py-16 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
      <div class="animate-fade-up">
        <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">
          O grimório
        </h2>
        <p class="mt-2 text-sm text-ink-muted">Por que existimos.</p>
      </div>
      <div class="prose-studio animate-fade-up-delay space-y-0">
        <p>
          A <strong>{site.name}</strong> nasceu da mistura entre magia de
          meia-noite, café ainda fumegando e a vontade teimosa de fazer jogos
          com alma — mundos pequenos e densos, onde cada detalhe é pintado à mão.
        </p>
        <p>
          Este site é o nosso hub oficial: o lugar onde publicamos jogos, notícias,
          patch notes, divulgações e os diários de criação enquanto os
          projetos ganham forma.
        </p>
        <p>
          Se você curte atmosfera, exploração e histórias que pedem uma xícara
          quente ao lado, está na dungeon certa. Sinta a vontade de explorar, de
          se aventurar e de se perder em nossos mundos.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-arcane/10 bg-night-lift/40">
    <div class="mx-auto max-w-5xl px-5 py-14 sm:px-8 sm:py-16">
      <div class="animate-fade-up mb-10 max-w-xl">
        <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">
          O que tem por aqui
        </h2>
        <p class="mt-2 text-sm text-ink-muted">
          Três caminhos para acompanhar o estúdio.
        </p>
      </div>

      <ul class="animate-fade-up-delay divide-y divide-arcane/15 border-y border-arcane/15">
        <li class="group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:justify-between sm:gap-8">
          <div>
            <h3 class="font-display text-xl font-semibold text-ink transition-colors group-hover:text-arcane-bright">
              Jogos
            </h3>
            <p class="mt-1 max-w-md text-sm text-ink-muted">
              O catálogo do que estamos fazendo — e do que já saiu para o mundo.
            </p>
          </div>
          <a
            href={path("/games")}
            class="shrink-0 text-sm font-medium text-arcane-bright transition hover:text-amber-soft"
          >
            Ver catálogo →
          </a>
        </li>
        <li class="group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:justify-between sm:gap-8">
          <div>
            <h3 class="font-display text-xl font-semibold text-ink transition-colors group-hover:text-arcane-bright">
              Blog
            </h3>
            <p class="mt-1 max-w-md text-sm text-ink-muted">
              Notícias, patch notes e divulgações — o registro vivo do estúdio.
            </p>
          </div>
          <a
            href={path("/blog")}
            class="shrink-0 text-sm font-medium text-arcane-bright transition hover:text-amber-soft"
          >
            Ler posts →
          </a>
        </li>
        <li class="group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:justify-between sm:gap-8">
          <div>
            <h3 class="font-display text-xl font-semibold text-ink transition-colors group-hover:text-arcane-bright">
              Redes
            </h3>
            <p class="mt-1 max-w-md text-sm text-ink-muted">
              Bastidores, trailers e conversa direta com quem joga junto.
            </p>
          </div>
          <div class="flex flex-wrap gap-4 text-sm font-medium">
            <a
              href={site.social.twitter}
              class="text-arcane-bright transition hover:text-amber-soft"
              target="_blank"
              rel="noopener noreferrer">Twitter / X</a
            >
            <a
              href={site.social.discord}
              class="text-arcane-bright transition hover:text-amber-soft"
              target="_blank"
              rel="noopener noreferrer">Discord</a
            >
            <a
              href={site.social.youtube}
              class="text-arcane-bright transition hover:text-amber-soft"
              target="_blank"
              rel="noopener noreferrer">YouTube</a
            >
          </div>
        </li>
      </ul>
    </div>
  </section>

  <section class="border-t border-arcane/10">
    <div class="mx-auto max-w-5xl px-5 py-14 sm:px-8 sm:py-20">
      <div class="animate-fade-up max-w-2xl">
        <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">
          Fale conosco
        </h2>
        <p class="mt-3 text-ink-muted">
          Parcerias, imprensa, feedback ou só um oi — a porta do estúdio está
          aberta.
        </p>
        <a
          href={`mailto:${site.email}`}
          class="mt-8 inline-flex rounded-md bg-arcane px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-arcane-bright"
        >
          {site.email}
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
